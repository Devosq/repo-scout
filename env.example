# Repo Scout configuration — copy to .env (chmod 600)

# Telegram bot token (BotFather). Required for push reports.
TELEGRAM_BOT_TOKEN=

# Chat id for the dedicated repo-scout chat. Detect with: python3 setup_telegram.py
TELEGRAM_CHAT_ID=

# Optional GitHub personal access token (classic, no scopes needed).
# Raises search rate limit 10/min -> 30/min. Works without one.
GITHUB_TOKEN=

# Local Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b-32k
